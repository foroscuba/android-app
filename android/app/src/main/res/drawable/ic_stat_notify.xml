<?xml version="1.0" encoding="utf-8"?>
<!--
  Monochrome white silhouette of the FCuba logo (two stacked speech-bubble
  rounded rectangles, F-shape). Used as the small status-bar icon for FCM
  push notifications. Android masks the alpha and tints with the system /
  notification colour, so the design must be flat-white-on-transparent.

  Wired in AndroidManifest.xml via:
      <meta-data
          android:name="com.google.firebase.messaging.default_notification_icon"
          android:resource="@drawable/ic_stat_notify" />
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Top bubble (the cross-bar of the F) -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M5,3 L19,3 C20.1,3 21,3.9 21,5 L21,9 C21,10.1 20.1,11 19,11 L9,11 L5,14 L5,5 C5,3.9 5.9,3 7,3 Z" />

    <!-- Bottom bubble (the lower arm of the F) -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M5,13 L15,13 C16.1,13 17,13.9 17,15 L17,19 C17,20.1 16.1,21 15,21 L9,21 L5,23 L5,15 C5,13.9 5.9,13 7,13 Z" />

</vector>
