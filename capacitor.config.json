{
  "appId": "net.fcuba.app",
  "appName": "FCuba",
  "webDir": "www",
  "server": {
    "androidScheme": "https",
    "hostname": "app.fcuba.net",
    "allowNavigation": [
      "fcuba.net",
      "*.fcuba.net"
    ]
  },
  "android": {
    "allowMixedContent": false,
    "captureInput": false,
    "webContentsDebuggingEnabled": false,
    "appendUserAgent": "FCubaApp/1.0 (Android)",
    "backgroundColor": "#0F1115"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 800,
      "launchAutoHide": true,
      "launchFadeOutDuration": 200,
      "backgroundColor": "#0F1115",
      "androidScaleType": "CENTER_CROP",
      "showSpinner": false,
      "splashFullScreen": false,
      "splashImmersive": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0F1115",
      "overlaysWebView": false
    },
    "Keyboard": {
      "resize": "native",
      "resizeOnFullScreen": true
    }
  }
}
